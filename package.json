{
  "name": "@flowscripter/dynamic-cli-framework-api",
  "version": "1.4.0",
  "description": "API for https://github.com/flowscripter/dynamic-cli-framework",
  "keywords": [
    "bun",
    "cli",
    "dynamic",
    "dynamic-cli-framework",
    "framework",
    "import",
    "plugin"
  ],
  "homepage": "https://github.com/flowscripter/dynamic-cli-framework-api#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flowscripter/dynamic-cli-framework-api.git"
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@flowscripter/dynamic-plugin-framework": "1.10.5",
    "@types/bun": "^1.3.14",
    "highlight.js": "^11.11.1",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "prettier": "^3.9.5"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "typedocOptions": {
    "readme": "none",
    "exclude": [
      "tests/**"
    ],
    "externalSymbolLinkMappings": {
      "@flowscripter/dynamic-plugin-framework": {
        "default": "https://flowscripter.github.io/dynamic-plugin-framework/interfaces/PluginDescriptor.html"
      }
    }
  }
}
